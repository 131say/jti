REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_EXTERNAL_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=aiforge
S3_SECRET_KEY=aiforge_secret
S3_BUCKET=artifacts

# Auth (Инкремент №38): Google Sign-In + JWT для /projects
# OAuth Client (Web) — тот же Client ID, что и NEXT_PUBLIC_GOOGLE_CLIENT_ID на фронте
# GOOGLE_CLIENT_ID=
# Секрет подписи access_token (минимум 32 случайных символа)
# JWT_SECRET=
# Срок жизни JWT в днях (опционально)
# JWT_EXP_DAYS=7

# Gemini (POST /api/v1/jobs с телом {"prompt": "..."})
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
